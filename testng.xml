<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!-- parallel="methods" = multiple test methods run simultaneously -->
<!-- thread-count="3" = 3 tests run at the same time -->
<suite name="ParaBank Banking Test Suite">

    <listeners>
        <listener class-name="listeners.TestListener"/>
    </listeners>

    <test name="Smoke Tests">
        <classes>
            <class name="tests.RegisterTest"/>
            <class name="tests.LoginTest"/>
        </classes>
    </test>

    <test name="Account Tests">
        <classes>
            <class name="tests.AccountsOverviewTest"/>
        </classes>
    </test>

    <test name="Transaction Tests">
        <classes>
            <class name="tests.TransferFundsTest"/>
            <class name="tests.BillPayTest"/>
        </classes>
    </test>

    <test name="Data Driven Tests">
        <classes>
            <class name="tests.DataDrivenLoginTest"/>
        </classes>
    </test>
    
	 <test name="E2E Tests">
	    <classes>
	        <class name="tests.EndToEndTest"/>
	    </classes>
	</test>
